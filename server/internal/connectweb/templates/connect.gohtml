<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Connect {{.ProviderName}} — Beecon</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>@import url("/connect/style.css");</style>
</head>
<body>
  <main class="card">
    {{if .ProviderLogo}}<img class="logo" src="{{.ProviderLogo}}" alt="{{.ProviderName}} logo">{{end}}
    <h1>Connect {{.ProviderName}}</h1>
    <p>Beecon needs your permission to connect your {{.ProviderName}} account.</p>
    <a class="connect-button" href="{{.AuthorizeURL}}">Connect</a>
  </main>
</body>
</html>
