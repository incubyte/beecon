<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Connect {{.ProviderName}} — Beecon</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>@import url("/connect/style.css");</style>
</head>
<body>
  <main class="card card--form">
    {{if .ProviderLogo}}<img class="logo" src="{{.ProviderLogo}}" alt="{{.ProviderName}} logo">{{end}}
    <h1>Connect {{.ProviderName}}</h1>
    <p class="intro">Before connecting, {{.ProviderName}} needs a few details from you.</p>
    <form method="post" action="/connect/{{.Token}}/params">
      {{range .Fields}}
      <div class="field">
        <label for="field-{{.Name}}">{{.DisplayName}}{{if .Required}} *{{end}}</label>
        {{if .Description}}<p class="field-description">{{.Description}}</p>{{end}}
        <input
          id="field-{{.Name}}"
          name="{{.Name}}"
          type="{{if .Secret}}password{{else}}text{{end}}"
          value="{{.Value}}"
          {{if .Required}}required{{end}}
          aria-invalid="{{if .Error}}true{{else}}false{{end}}"
        >
        {{if .Error}}<p class="field-error">{{.Error}}</p>{{end}}
      </div>
      {{end}}
      <button class="connect-button connect-button--block" type="submit">Continue</button>
    </form>
  </main>
</body>
</html>
