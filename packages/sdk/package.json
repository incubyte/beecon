{
  "name": "@beecon/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Beecon API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/incubyte/beecon.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.js"
    },
    "./mastra": {
      "types": "./dist/mastra.d.ts",
      "import": "./dist/mastra.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.examples.json",
    "prepublishOnly": "npm run build && npm run test"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@mastra/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@mastra/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
