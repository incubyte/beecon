    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "jsdom": "26.1.0",
    "msw": "^2.15.0",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
